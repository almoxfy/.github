# =============================================================================
# .gitignore — ignores generated files, local configs and editor artifacts
# to keep the repository clean, deterministic and free of local secrets.
# =============================================================================

# ---- Secrets / local configuration -------------------------------------------
.env
.env.*
!.env.example
tests/.env
*.pem
!sealed-secrets/**/*.pem
*.key
*.crt
secrets/
.secrets/
*-secret.yaml

# ---- Python ------------------------------------------------------------------
# ---- Bytecode / runtime -------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ---- Build / packaging --------------------------------------------------------
build/
dist/
develop-eggs/
downloads/
eggs/
.eggs/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.manifest
*.spec

# ---- Installer logs -----------------------------------------------------------
pip-log.txt
pip-delete-this-directory.txt

# ---- Tests / coverage ---------------------------------------------------------
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
nosetests.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
pytestdebug.log

# ---- Web frameworks (Django / Flask / Scrapy) --------------------------------
local_settings.py
db.sqlite3
db.sqlite3-journal
instance/
.webassets-cache
.scrapy

# ---- Generated docs -----------------------------------------------------------
docs/_build/
doc/_build/
target/
/site

# ---- Notebooks / interactive shell --------------------------------------------
.ipynb_checkpoints
profile_default/
ipython_config.py

# ---- Version file / local environments ----------------------------------------
.python-version
__pypackages__/
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
venv*
pythonenv*

